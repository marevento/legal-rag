# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_CHAT_MINI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_DIMENSIONS=3072

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=your-key-here
AZURE_SEARCH_INDEX=mietrecht-norms

# Azure Storage (optional, for blob storage)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=documents

# Authentication (magic-link)
JWT_SECRET=generate-with-openssl-rand-hex-32
ADMIN_EMAILS=your-email@example.com
APP_URL=http://localhost:50505
AZURE_COMMUNICATION_CONNECTION_STRING=endpoint=https://your-acs.communication.azure.com/;accesskey=...
ACS_SENDER_ADDRESS=DoNotReply@your-acs-domain.azurecomm.net

# Azure Monitor (auto-set by Bicep in production)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# CORS (set to frontend origin in production, e.g. https://my-app.azurecontainerapps.io)
CORS_ORIGIN=

# Server
DEBUG=false

# Cost controls
# Set Azure spending alerts via CLI:
# az consumption budget create --budget-name legal-rag-budget --amount 50 \
#   --time-grain monthly --category cost --resource-group <your-rg>

# RAG Configuration
RAG_APPROACH=custom
RAG_TOP_K=5
RAG_TEMPERATURE=0
RAG_SEARCH_STRATEGY=hybrid
